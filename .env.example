# Copy to .env and fill in values. Never commit .env to source control.

NEWSAPI_KEY=your_newsapi_key_here

PGHOST=your-neon-host.neon.tech
PGDATABASE=neondb
PGUSER=neondb_owner
PGPASSWORD=your_password_here
PGSSLMODE=require

# Optional: override fetch schedule (default: every 3 hours)
# FETCH_CRON=0 0 */3 * * *

# News source IDs and search queries are in src/main/resources/application.properties
# under newsapi.category.* — edit there to change which India news is fetched.

# NOTE: POST /api/admin/fetch-now is unprotected in MVP.
# Add ADMIN_API_KEY protection before any public deployment.
